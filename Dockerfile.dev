FROM golang:1.25-alpine

WORKDIR /app

# Встановлюємо air для hot reload (старша версія для Go 1.24.2)
RUN go install github.com/cosmtrek/air@v1.51.0

# Копіюємо залежності
COPY go.* ./
RUN go mod download

# Копіюємо весь проект
COPY . .

# Копіюємо конфіг для air
COPY .air.toml .

# Експонуємо порт
EXPOSE 8080

# Запускаємо air для розробки з hot reload
CMD ["air", "-c", ".air.toml"]
